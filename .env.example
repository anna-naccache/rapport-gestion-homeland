# Variables d'environnement - copiez ce fichier en .env et remplissez vos identifiants

# HBO (Gestion immobilière)
HBO_EMAIL=votre.email@example.com
HBO_PASSWORD=votre_mot_de_passe

# Ringover (Téléphonie)
RINGOVER_API_KEY=votre_cle_api_ringover

# Front (Emails)
FRONT_TOKEN=votre_token_front

# Port du serveur (optionnel, Railway le définit automatiquement)
# PORT=5055
